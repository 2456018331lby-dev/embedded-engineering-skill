{
  "schema_version": 1,
  "project_name": "esp32_c3_sensor_node",
  "description": "Battery/USB-powered ESP32-C3 sensor node baseline with USB-C power, 3.3V LDO, I2C sensor, UART debug, boot/reset support, and optional 2.4GHz antenna path.",
  "input_power": {
    "source": "usb_c",
    "voltage": 5.0,
    "net": "+VBUS",
    "esd_protection": true
  },
  "power": {
    "main_regulator": "TLV75533PDBVR",
    "rails": [
      {
        "name": "+3V3",
        "voltage": 3.3,
        "current_ma": 250,
        "source": "TLV75533PDBVR"
      }
    ]
  },
  "mcu": "ESP32-C3-MINI-1",
  "sensors": [
    {
      "part": "SHT31-DIS",
      "interface": "i2c",
      "ref": "U3"
    }
  ],
  "debug": {
    "uart_header": true,
    "boot_button": false,
    "reset_button": true
  },
  "rf": {
    "enabled": true,
    "antenna": "PCB_ANT_2G4",
    "matching": "pi_placeholder",
    "test_connector": "U.FL"
  },
  "indicators": [
    {
      "name": "STATUS",
      "color": "green",
      "gpio": "GPIO3"
    }
  ]
}